{
    "name": "doc/docx2jats",
    "description": "DOCX to JATS XML converter",
    "type": "library",
    "license": "GPLv3",
    "authors": [
        {
            "name": "Vitaliy Bezsheiko",
            "email": "vitaliybezsh@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "citation-style-language/locales",
                "version":"1.0.0",
                "source": {
                    "type": "git",
                    "url": "https://github.com/citation-style-language/locales.git",
                    "reference": "master"
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "citation-style-language/styles",
                "version":"1.0.0",
                "source": {
                    "type": "git",
                    "url": "https://github.com/citation-style-language/styles.git",
                    "reference": "master"
                }
            }
        }
    ],
    "require": {
        "php": "^7.3|^8.0",
        "ext-zip": "^1.15",
		"ext-dom": "*",
		"ext-json": "*",
        "citation-style-language/locales": "@dev",
        "citation-style-language/styles": "@dev",
        "seboettg/collection": "v3.1.0",
        "seboettg/citeproc-php": "^2"
	},
    "autoload": {
        "psr-4": {
            "docx2jats\\": "src/docx2jats"
        }
    }
}
